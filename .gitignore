# Dependencies — all workspace packages
**/node_modules
.pnp
.pnp.*

# Build output
dist/
build/
out/
.next/

# Turborepo cache
.turbo/

# Test coverage
**/coverage

# TypeScript incremental build info
**/*.tsbuildinfo

# PWA — service worker and workbox files generated by vite-plugin-pwa
apps/web/public/sw.js
apps/web/public/sw.js.map
apps/web/public/workbox-*.js
apps/web/public/workbox-*.js.map

# Environment files — never commit real secrets
.env
.env.local
.env.*.local
.env.production

# OS artifacts
.DS_Store
Thumbs.db

# Editor
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Certificates & keys
*.pem
*.key
*.p12
*.pfx

# Prisma
prisma/migrations/dev.db
prisma/*.db

# Vercel
.vercel
