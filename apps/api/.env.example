# Copy to .env and fill in values before running outside Docker

# PostgreSQL — format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Railway provides DATABASE_URL automatically when a Postgres plugin is added
DATABASE_URL=postgresql://calculator:calculator@localhost:5432/calculator_dev

# Redis — Railway provides REDIS_URL automatically when a Redis plugin is added
REDIS_URL=redis://localhost:6379

# JWT — generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# API server port — Railway sets PORT automatically
PORT=3000

# Allowed CORS origin (your Vercel frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development

# Sentry error tracking — optional; leave empty to disable
SENTRY_DSN=
