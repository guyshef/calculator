# Copy to .env.local and fill in values before running outside Docker
# In production, set these as environment variables in Vercel

# Backend API base URL (no trailing slash)
# Production: your Railway API URL, e.g. https://calculator-api.up.railway.app
VITE_API_URL=http://localhost:3000

# Sentry error tracking — optional; leave empty to disable
VITE_SENTRY_DSN=
